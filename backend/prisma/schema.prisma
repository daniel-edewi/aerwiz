generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  nationality    String       @default("NG")
  dateOfBirth    DateTime?
  passportNumber String?
  passportExpiry DateTime?
  isVerified     Boolean      @default(false)
  isActive       Boolean      @default(true)
  role           Role         @default(USER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  bookings       Booking[]
  priceAlerts    PriceAlert[]
  payments       Payment[]

  @@map("users")
}

model Booking {
  id               String        @id @default(uuid())
  bookingReference String        @unique
  userId           String?
  user             User?         @relation(fields: [userId], references: [id])
  flightData       Json
  origin           String
  destination      String
  departureDate    DateTime
  arrivalDate      DateTime
  airline          String
  flightNumber     String
  cabinClass       CabinClass    @default(ECONOMY)
  tripType         TripType      @default(ONE_WAY)
  baseFare         Float
  taxes            Float
  serviceFee       Float
  totalAmount      Float
  currency         String        @default("NGN")
  status           BookingStatus @default(PENDING)
  amadeusOrderId   String?
  pnrCode          String?
  ticketNumbers    String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  passengers       Passenger[]
  payment          Payment?

  @@map("bookings")
}

model Passenger {
  id             String        @id @default(uuid())
  bookingId      String
  booking        Booking       @relation(fields: [bookingId], references: [id])
  type           PassengerType @default(ADULT)
  title          String
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  nationality    String
  passportNumber String?
  passportExpiry DateTime?
  email          String?
  phone          String?
  createdAt      DateTime      @default(now())

  @@map("passengers")
}

model Payment {
  id                String          @id @default(uuid())
  bookingId         String          @unique
  booking           Booking         @relation(fields: [bookingId], references: [id])
  userId            String?
  user              User?           @relation(fields: [userId], references: [id])
  amount            Float
  currency          String          @default("NGN")
  provider          PaymentProvider
  providerReference String?
  providerResponse  Json?
  status            PaymentStatus   @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("payments")
}

model Airport {
  id          String  @id @default(uuid())
  iataCode    String  @unique
  name        String
  city        String
  country     String
  countryCode String
  timezone    String
  isActive    Boolean @default(true)

  @@map("airports")
}

model PriceAlert {
  id            String    @id @default(uuid())
  userId        String
  origin        String
  destination   String
  targetPrice   Float
  cabinClass    String    @default("ECONOMY")
  departureDate String?
  isActive      Boolean   @default(true)
  lastChecked   DateTime?
  lastPrice     Float?
  triggeredAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENTAGE")
  discountValue Float
  minAmount     Float?
  maxDiscount   Float?
  usageLimit    Int?
  usageCount    Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
  SUPPORT
}

enum BookingStatus {
  PENDING
  PAYMENT_PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  STRIPE
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

enum CabinClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}// Add this model to your existing schema.prisma file
// Located at: ~/Documents/aerwiz/backend/prisma/schema.prisma

model BlogPost {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  excerpt     String    @default("")
  content     String    @db.Text
  category    String    @default("General")
  image       String    @default("")
  readTime    String    @default("5 min read")
  author      String    @default("Aerwiz Team")
  published   Boolean   @default(true)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
